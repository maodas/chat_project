# ==============================================
# Configuración General
# ==============================================
# Nota: Cambia estos valores en un entorno de producción real.

# ==============================================
# PostgreSQL (Base de datos raíz)
# ==============================================
POSTGRES_ROOT_USER=postgres
POSTGRES_ROOT_PASSWORD=super_secret_root_password

# ==============================================
# n8n
# ==============================================
# La contraseña de BD debe coincidir con la definida en infrastructure/docker/init.sql
N8N_DB_PASSWORD=n8n_password
# Credenciales para acceder a la interfaz web de n8n
N8N_USER=admin
N8N_PASSWORD=admin_secret
# URL pública (necesario para webhooks de n8n)
N8N_WEBHOOK_URL=http://localhost:5678
# Clave de encriptación de credenciales (genera una segura, ej: openssl rand -hex 16)
N8N_ENCRYPTION_KEY=super_secret_n8n_encryption_key

# ==============================================
# Chatwoot
# ==============================================
# La contraseña de BD debe coincidir con la definida en infrastructure/docker/init.sql
CHATWOOT_DB_PASSWORD=chatwoot_password
# Genera una clave secreta fuerte: `openssl rand -hex 64`
CHATWOOT_SECRET_KEY_BASE=replace_this_with_a_super_secret_long_string_generated_by_openssl
# URL de acceso para Chatwoot
CHATWOOT_FRONTEND_URL=http://localhost:3000

# ==============================================
# Metabase
# ==============================================
# La contraseña de BD debe coincidir con la definida en infrastructure/docker/init.sql
METABASE_DB_PASSWORD=metabase_password
